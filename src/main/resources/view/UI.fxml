<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane stylesheets="@/decor/login_style.css" styleClass="main-root" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.prison.ptpmud.Controller.controlLoginUI">
    
    <HBox styleClass="login-card" maxWidth="800" maxHeight="500">
        
        <VBox styleClass="left-pane" HBox.hgrow="ALWAYS" alignment="CENTER">
            <ImageView fitWidth="350" preserveRatio="true">
                <image>
                    <Image url="@/images/logo_left.png" />
                </image>
            </ImageView>
        </VBox>

        <VBox styleClass="right-pane" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="22">
            <padding>
                <Insets top="30" right="45" bottom="30" left="45"/>
            </padding>

            <HBox alignment="CENTER" spacing="8">
                <Label text="🔒" styleClass="icon-small"/>
                <Label text="SECURE ACCESS" styleClass="section-header"/>
            </HBox>

            <VBox spacing="8">
                <Label text="AGENT ID" styleClass="input-label"/>
                <HBox styleClass="input-box" alignment="CENTER_LEFT" spacing="10">
                    <Label text="👤" styleClass="input-icon"/>
                    <TextField fx:id="accountTXT" promptText="Enter Agent ID" styleClass="input-field" HBox.hgrow="ALWAYS"/>
                    <Label text="⌨" styleClass="input-icon"/>
                </HBox>
            </VBox>

            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT">
                    <Label text="PASSWORD" styleClass="input-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Show Password" styleClass="link-small"/>
                </HBox>
                <HBox styleClass="input-box" alignment="CENTER_LEFT" spacing="10">
                    <Label text="🔒" styleClass="input-icon"/>
                    <PasswordField fx:id="passTXT" promptText="••••••••" styleClass="input-field" HBox.hgrow="ALWAYS"/>
                    <Label text="👁" styleClass="input-icon"/>
                </HBox>
            </VBox>

            <VBox alignment="CENTER" spacing="15">
                <HBox alignment="CENTER" spacing="10">
                    <Separator HBox.hgrow="ALWAYS" styleClass="divider"/>
                    <Label text="OR LOG IN WITH BIOMETRICS" styleClass="divider-text"/>
                    <Separator HBox.hgrow="ALWAYS" styleClass="divider"/>
                </HBox>
                <HBox alignment="CENTER" spacing="25">
                    <Button styleClass="bio-btn" text="☝"/>
                    <Button styleClass="bio-btn" text="☺"/>
                </HBox>
            </VBox>

            <Button text="ACCESS SYSTEM →" onAction="#Login" styleClass="btn-login" maxWidth="Infinity"/>

            <VBox alignment="CENTER" spacing="5">
                <Label text="Forgot Password?" styleClass="link-footer"/>
                <Label text="Request System Access" styleClass="link-footer"/>
            </VBox>
        </VBox>
    </HBox>
</StackPane>