<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #ecf0f1; -fx-border-color: #2c3e50; -fx-border-width: 5;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.prison.ptpmud.Controller.PrisonerCVController">
    
    <top>
        <VBox alignment="CENTER" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="HỒ SƠ LÝ LỊCH CẢI TẠO" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;" />
            <Label text="Lưu trữ nội bộ - Bộ Công An" style="-fx-text-fill: #bdc3c7; -fx-font-style: italic;" />
        </VBox>
    </top>

    <center>
        <HBox spacing="30" style="-fx-padding: 30;">
            <VBox spacing="15" alignment="TOP_CENTER" prefWidth="200" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                <ImageView fx:id="imgAvatar" fitHeight="150" fitWidth="120" preserveRatio="true" style="-fx-border-color: black; -fx-border-width: 2;">
                    <image>
                        <Image url="@../images/logo.png" />
                    </image>
                </ImageView>
                <Label text="SỐ DANH BỘ" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                <Label fx:id="lblId" text="PN100X" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" />
            </VBox>

            <VBox spacing="20" prefWidth="350">
                <GridPane vgap="15" hgap="10">
                    <Label text="Họ và Tên:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                    <Label fx:id="lblName" text="..." GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-font-size: 16px; -fx-font-weight: bold;" />

                    <Label text="Tội Danh:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                    <Label fx:id="lblCrime" text="..." wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-font-size: 14px; -fx-text-fill: #c0392b;" />

                    <Label text="Buồng Giam:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                    <Label fx:id="lblCell" text="..." GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-font-size: 14px;" />

                    <Label text="Ngày Sinh:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                    <Label fx:id="lblDate" text="..." GridPane.columnIndex="1" GridPane.rowIndex="3" style="-fx-font-size: 14px;" />

                    <Label text="Trạng Thái:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                    <Label fx:id="lblStatus" text="..." GridPane.columnIndex="1" GridPane.rowIndex="4" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
                </GridPane>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-padding: 15; -fx-background-color: #bdc3c7;">
            <Button text="ĐÓNG HỒ SƠ" onAction="#handleClose" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 30; -fx-cursor: hand;" />
        </HBox>
    </bottom>

</BorderPane>
