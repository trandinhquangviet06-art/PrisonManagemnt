<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #f4f6f7;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.prison.ptpmud.Controller.GuardManagementController">
    
    <top>
        <VBox alignment="CENTER" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="HỆ THỐNG QUẢN LÝ QUẢN NGỤC &amp; CÁN BỘ CẢI TẠO" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;" />
        </VBox>
    </top>

    <center>
        <HBox spacing="20" style="-fx-padding: 20;">
            <VBox spacing="12" prefWidth="360" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                <Label text="Thông Tin Hồ Sơ Cán Bộ" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                <Separator />
                
                <VBox alignment="CENTER" spacing="8" style="-fx-background-color: #fcfcfc; -fx-padding: 10; -fx-border-color: #dcdde1; -fx-border-radius: 5;">
                    <StackPane style="-fx-border-color: #bdc3c7; -fx-border-width: 1; -fx-background-color: #f5f6fa;" prefWidth="110" prefHeight="130" maxWidth="110" maxHeight="130">
                        <ImageView fx:id="imgAvatar" fitWidth="108" fitHeight="128" pickOnBounds="true" preserveRatio="true" />
                    </StackPane>
                    <Button text="Chọn ảnh hồ sơ" onAction="#handleChooseImage" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-size: 11px; -fx-cursor: hand;" />
                </VBox>

                <GridPane vgap="10" hgap="10">
                    <Label text="Mã Quản Ngục:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtId" promptText="Ví dụ: QN001" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <Label text="Họ và Tên:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtName" promptText="Nhập đầy đủ họ tên" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <Label text="Ngày Sinh:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtDob" promptText="YYYY-MM-DD" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <Label text="Giới Tính:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtGender" promptText="Nam / Nữ" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                    <Label text="Số Điện Thoại:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtPhone" promptText="Nhập số liên hệ" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                </GridPane>

                <Separator />
                
                <FlowPane hgap="8" vgap="8" alignment="CENTER">
                    <Button text="Thêm Mới" onAction="#handleAdd" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 10; -fx-cursor: hand;" />
                    <Button text="Cập Nhật" onAction="#handleUpdate" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 10; -fx-cursor: hand;" />
                    <Button text="Xóa" onAction="#handleDelete" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 10; -fx-cursor: hand;" />
                    <Button text="Làm Trống" onAction="#handleClear" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 10; -fx-cursor: hand;" />
                    
                    <Button text="Cấp Tài Khoản 🔑" onAction="#handleOpenCreateAccount" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 10; -fx-cursor: hand;" />
                    <Button text="🔙 Quay Lại" onAction="#handleBack" style="-fx-background-color: #1e272e; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 10; -fx-cursor: hand;" />
                </FlowPane>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" spacing="10">
                <TableView fx:id="tvGuards" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5;">
                    <columns>
                        <TableColumn fx:id="colId" text="Mã QN" prefWidth="100" />
                        <TableColumn fx:id="colName" text="Họ và Tên" prefWidth="190" />
                        <TableColumn fx:id="colDob" text="Ngày Sinh" prefWidth="120" />
                        <TableColumn fx:id="colGender" text="Giới Tính" prefWidth="90" />
                        <TableColumn fx:id="colPhone" text="Số Điện Thoại" prefWidth="140" />
                    </columns>
                </TableView>
            </VBox>
        </HBox>
    </center>
</BorderPane>
