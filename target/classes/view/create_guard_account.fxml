<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #f4f6f9;" stylesheets="@../css/main.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.prison.ptpmud.Controller.CreateGuardAccountController">
    
    <VBox spacing="20" maxWidth="500" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 40;">
        
        <VBox alignment="CENTER" spacing="5">
            <Label text="🔑 CẤP TÀI KHOẢN QUẢN NGỤC" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Quyền hạn thuộc Tổng Cục Trưởng hệ thống" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
        </VBox>

        <Separator/>

        <VBox spacing="15">
            <VBox spacing="5">
                <Label text="Chọn cán bộ quản ngục nhận tài khoản:" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                <ComboBox fx:id="cbQuanNguc" promptText="-- Lựa chọn cán bộ chưa có tài khoản --" maxWidth="Infinity" style="-fx-padding: 5; -fx-background-radius: 5; -fx-border-color: #bdc3c7; -fx-border-radius: 5;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Tên đăng nhập hệ thống:" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                <TextField fx:id="txtTenDangNhap" promptText="Nhập tên tài khoản (VD: cb_quanguyenvana)" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #bdc3c7; -fx-border-radius: 5;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Mật khẩu khởi tạo:" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                <PasswordField fx:id="txtMatKhau" promptText="Nhập mật khẩu đăng nhập" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #bdc3c7; -fx-border-radius: 5;"/>
            </VBox>
        </VBox>

        <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding: 20 0 0 0;">
            <Button text="⬅ Quay lại" onAction="#handleBack" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 15; -fx-cursor: hand;"/>
            <Region HBox.hgrow="ALWAYS" /> <Button text="❌ Xóa chữ" onAction="#handleClear" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 15; -fx-cursor: hand;"/>
            <Button text="✅ CẤP TÀI KHOẢN" onAction="#handleCreateAccount" style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 15; -fx-cursor: hand;"/>
        </HBox>
        
    </VBox>
</VBox>
