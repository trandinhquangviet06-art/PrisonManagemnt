<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720.0" prefWidth="1280.0" styleClass="root-admin" stylesheets="@../decor/admin_dashboard.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.prison.ptpmud.Controller.AdminDashboardController">
    <left>
        <VBox spacing="15" styleClass="sidebar" prefWidth="260">
            <Label text="TỔNG CỤC TRƯỞNG" styleClass="sidebar-title" maxWidth="Infinity"/>
            <Separator styleClass="sidebar-separator"/>
            
            <Button text="🏠 Bảng Điều Khiển" maxWidth="Infinity" styleClass="menu-btn-active"/>
            <Button text="👥 Quản Lý Tội Nhân" onAction="#handleOpenPrisonerMgmt" maxWidth="Infinity" styleClass="menu-btn"/>
            <Button text="👮 Quản Lý Quản Ngục" onAction="#handleOpenGuardMgmt" maxWidth="Infinity" styleClass="menu-btn"/>
            <Button text="🔑 Cấp Tài Khoản" onAction="#handleOpenCreateAccount" maxWidth="Infinity" styleClass="menu-btn"/>
            
            <Region VBox.vgrow="ALWAYS" />
            <Button text="🔒 ĐĂNG XUẤT" onAction="#handleLogout" maxWidth="Infinity" styleClass="btn-logout"/>
        </VBox>
    </left>
    
    <center>
        <VBox spacing="30" styleClass="content-area">
            <HBox spacing="20" alignment="CENTER_LEFT">
                <VBox>
                    <Label text="TRUNG TÂM ĐIỀU HÀNH TỔNG CỤC" styleClass="page-title"/>
                    <Label text="Hệ thống giám sát tối cao - Phân quyền quản trị" styleClass="page-subtitle"/>
                </VBox>
            </HBox>
            
            <HBox spacing="25">
                <VBox alignment="CENTER" spacing="15" prefWidth="300" prefHeight="260" styleClass="dashboard-card">
                    <Label text="👥" styleClass="card-icon"/>
                    <Label text="Quản Lý Tội Nhân" styleClass="card-title"/>
                    <Label text="Xem danh sách, kiểm tra hồ sơ lý lịch và trạng thái cải tạo (CV)." wrapText="true" styleClass="card-description" alignment="CENTER" textAlignment="CENTER"/>
                    <Button text="Mở Sổ Quản Lý ➔" onAction="#handleOpenPrisonerMgmt" styleClass="card-btn-blue"/>
                </VBox>
                
                <VBox alignment="CENTER" spacing="15" prefWidth="300" prefHeight="260" styleClass="dashboard-card">
                    <Label text="👮" styleClass="card-icon"/>
                    <Label text="Quản Lý Quản Ngục" styleClass="card-title"/>
                    <Label text="Thêm mới, xóa và kiểm tra danh sách tài khoản cán bộ trực ban." wrapText="true" styleClass="card-description" alignment="CENTER" textAlignment="CENTER"/>
                    <Button text="Quản Lý Cán Bộ ➔" onAction="#handleOpenGuardMgmt" styleClass="card-btn-green"/>
                </VBox>

                <VBox alignment="CENTER" spacing="15" prefWidth="300" prefHeight="260" styleClass="dashboard-card">
                    <Label text="🔑" styleClass="card-icon"/>
                    <Label text="Cấp Tài Khoản" styleClass="card-title"/>
                    <Label text="Khởi tạo tài khoản đăng nhập hệ thống và cấp mật khẩu cho cán bộ." wrapText="true" styleClass="card-description" alignment="CENTER" textAlignment="CENTER"/>
                    <Button text="Cấp Tài Khoản ➔" onAction="#handleOpenCreateAccount" styleClass="card-btn-orange"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
