<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.*?>

<BorderPane prefHeight="720.0" prefWidth="1280.0" stylesheets="@../css/main.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.prison.ptpmud.Controller.PrisonerManagementController">
    
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #2c3e50; -fx-padding: 15 30 15 30;">
            <Button onAction="#handleBack" styleClass="modern-button" style="-fx-background-color: #7f8c8d; -fx-min-width: 100;" text="⬅ QUAY LẠI" />
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;" text="DANH SÁCH QUẢN LÝ PHẠM NHÂN CHI TIẾT" />
            <Region HBox.hgrow="ALWAYS" />
            <ImageView fitHeight="40" preserveRatio="true">
                <Image url="@../images/logo.png" />
            </ImageView>
        </HBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 25; -fx-background-color: #f4f7f6;">
            
            <HBox alignment="CENTER_LEFT" spacing="15">
                <TextField fx:id="searchField" onKeyReleased="#handleSearch" prefWidth="450" promptText="Nhập Mã số danh bộ hoặc Họ tên phạm nhân..." styleClass="modern-input" />
                <Button onAction="#handleSearch" styleClass="modern-button" style="-fx-background-color: #3498db;" text="🔍 TÌM KIẾM" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10">
                    <Button onAction="#showAddDialog" styleClass="modern-button" style="-fx-background-color: #27ae60;" text="➕ THÊM MỚI" />
                    <Button onAction="#handleUpdatePrisoner" styleClass="modern-button" style="-fx-background-color: #f39c12;" text="📝 CẬP NHẬT" />
                    <Button onAction="#handleDeletePrisoner" styleClass="modern-button" style="-fx-background-color: #e74c3c;" text="🗑️ XÓA" />
                </HBox>
            </HBox>

            <TableView fx:id="prisonerTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5; -fx-border-radius: 5;">
                <columns>
                    <TableColumn fx:id="idColumn" prefWidth="120" text="SỐ DANH BỘ" />
                    <TableColumn fx:id="nameColumn" prefWidth="220" text="HỌ VÀ TÊN" />
                    <TableColumn fx:id="crimeColumn" prefWidth="250" text="TỘI DANH" />
                    <TableColumn fx:id="cellColumn" prefWidth="150" text="BUỒNG GIAM" />
                    <TableColumn fx:id="dateColumn" prefWidth="180" text="NGÀY NHẬP TRẠI" />
                    <TableColumn fx:id="statusColumn" prefWidth="180" text="TRẠNG THÁI" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_RIGHT" style="-fx-padding: 5 0 0 0;">
                <Label fx:id="totalLabel" style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Tổng số phạm nhân đang hiển thị: 0" />
            </HBox>
        </VBox>
    </center>
</BorderPane>
